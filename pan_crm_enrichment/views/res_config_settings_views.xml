<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_enrichment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.enrichment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='crm']" position="inside">

                <h2>AI Enrichment</h2>

                <div class="row mt-4 mb-4 o_settings_container">
                    <!-- API Key -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Anthropic API Key</span>
                            <div class="text-muted mb-3">
                                API key for Claude. Obtain one at
                                console.anthropic.com.
                            </div>
                            <div class="content-group">
                                <div class="row mt-2">
                                    <label class="col-lg-3 o_light_label"
                                           for="x_enrichment_api_key"/>
                                    <field name="x_enrichment_api_key"
                                           class="o_field_widget"
                                           password="True"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Website Scraping Toggle -->
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="x_enrichment_website_enabled"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Website Scraping</span>
                            <div class="text-muted">
                                When enabled, scrapes discovered websites
                                to extract company description and industry.
                            </div>
                        </div>
                    </div>
                </div>

            </xpath>
        </field>
    </record>
</odoo>
