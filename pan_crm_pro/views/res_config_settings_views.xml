<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_enrichment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ai.enrichment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='convert_visitor_setting_container']" position="inside">

                <setting string="AI Enrichment"
                         help="Enrich leads with contact data extracted from chatter emails using Claude AI">
                    <div class="content-group">
                        <div class="row mt-2">
                            <label class="col-lg-3 o_light_label"
                                   for="x_enrichment_api_key"/>
                            <field name="x_enrichment_api_key"
                                   password="True"/>
                        </div>
                    </div>
                    <div class="mt8">
                        <field name="x_enrichment_website_enabled"/>
                        <label for="x_enrichment_website_enabled"/>
                        <div class="text-muted ms-4">
                            When enabled, scrapes discovered websites
                            to extract company description and industry.
                        </div>
                    </div>
                </setting>

            </xpath>
        </field>
    </record>
</odoo>
